PORT=3040
# Cambie en producción (mínimo 32 caracteres aleatorios)
JWT_SECRET=cambie_esto_por_un_secreto_largo_y_aleatorio
JWT_EXPIRES_DAYS=7

# Origen permitido para CORS (ej. https://gneex.midominio.com). Vacío = refleja el Origin del request.
CORS_ORIGIN=

# Quién puede escribir en /api/v1/sync: all | admin
SYNC_WRITE_ROLE=admin

# Límite JSON (respaldos grandes; subir si hace falta)
JSON_LIMIT=80mb
